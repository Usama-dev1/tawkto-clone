{
  "terminal.integrated.allowChords": false,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.fontWeightBold": "bold",
  "terminal.integrated.altClickMovesCursor": false,
  "terminal.integrated.cursorStyleInactive": "line",
  "terminal.integrated.suggest.selectionMode": "never",
  "terminal.integrated.customGlyphs": false,
  "terminal.integrated.drawBoldTextInBrightColors": false,
  "terminal.integrated.enableFileLinks": "off",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.hideOnLastClosed": false,
  "terminal.integrated.initialHint": false,
  "terminal.integrated.rescaleOverlappingGlyphs": false,
  "terminal.integrated.stickyScroll.enabled": false,
  "terminal.integrated.tabs.enableAnimation": false,
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.suggest.providers": {
    "vscode.terminal-suggest": false
  },
  "terminal.integrated.windowsUseConptyDll": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[ css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
